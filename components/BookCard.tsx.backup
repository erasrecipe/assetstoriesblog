'use client';

import { Book } from '@/types/comparison';
import Image from 'next/image';
import { useState } from 'react';
import { getGoogleBooksCoverUrl, getPlaceholderCoverUrl } from '@/lib/imageUtils';

interface BookCardProps {
  book: Book;
}

export default function BookCard({ book }: BookCardProps) {
  const [imgSrc, setImgSrc] = useState(book.coverImage);
  const [hasError, setHasError] = useState(false);

  // Handle image load error - try fallbacks
  const handleImageError = () => {
    if (!hasError) {
      // First fallback: Skip Google Books (often returns "not available" image)
      // Go directly to nice placeholder
      const placeholderUrl = getPlaceholderCoverUrl(book.title);
      setImgSrc(placeholderUrl);
      setHasError(true);
    }
  };
  const renderStars = (rating: number) => {
    const fullStars = Math.floor(rating);
    const hasHalfStar = rating % 1 !== 0;
    const stars = [];
    
    for (let i = 0; i < fullStars; i++) {
      stars.push(<span key={`full-${i}`} className="inline-block animate-pulse" style={{ animationDelay: `${i * 0.1}s` }}>★</span>);
    }
    
    if (hasHalfStar) {
      stars.push(<span key="half">½</span>);
    }
    
    return stars;
  };

  return (
    <div className="bg-white dark:bg-gray-800 rounded-2xl p-6 sm:p-8 w-full max-w-sm shadow-2xl hover:transform hover:-translate-y-3 transition-all duration-300 group">
      {/* Book Cover */}
      <div className="w-full h-80 sm:h-96 bg-gradient-to-br from-gray-100 to-gray-200 dark:from-gray-700 dark:to-gray-600 rounded-xl mb-6 flex items-center justify-center overflow-hidden border-3 border-gray-300 dark:border-gray-500 shadow-lg group-hover:shadow-2xl transition-shadow duration-300 relative">
        {imgSrc ? (
          <Image
            src={imgSrc}
            alt={`${book.title} by ${book.author} - Book Cover`}
            fill
            sizes="(max-width: 640px) 100vw, (max-width: 768px) 50vw, 384px"
            className="object-cover"
            loading="eager"
            priority={true}
            onError={handleImageError}
          />
        ) : (
          <span className="text-center px-4 font-medium text-gray-500 dark:text-gray-400">📚 {book.title}</span>
        )}
      </div>
      
      {/* Book Title */}
      <h2 className="text-xl sm:text-2xl font-bold text-primary-dark dark:text-white mb-2 leading-tight">
        {book.title}
      </h2>
      
      {/* Author */}
      <p className="text-gray-600 dark:text-gray-400 mb-4 text-sm sm:text-base">
        by {book.author}
      </p>
      
      {/* Rating */}
      <div className="text-gold text-lg sm:text-xl mb-4 flex items-center gap-2">
        <span>{renderStars(book.rating)}</span>
        <span className="text-gray-600 dark:text-gray-400 text-sm">({book.rating}/5)</span>
      </div>
      
      {/* Price */}
      <div className="text-xl sm:text-2xl font-bold text-primary-darker dark:text-gold-light mb-6">
        ${book.price}
      </div>
      
      {/* Buy Button */}
      <a
        href={book.amazonUrl}
        target="_blank"
        rel="noopener noreferrer nofollow"
        className="block w-full text-center py-3 sm:py-4 bg-gradient-to-r from-gold to-gold-light text-primary-dark rounded-xl font-bold text-base sm:text-lg hover:shadow-xl transition-all transform hover:scale-105 hover:rotate-1"
      >
        Buy on Amazon →
      </a>
      
      {/* Affiliate Disclosure Notice */}
      <p className="text-xs text-gray-500 dark:text-gray-400 text-center mt-3 leading-relaxed">
        <span className="inline-block">💡 We earn from qualifying purchases.</span>{' '}
        <a href="/affiliate-disclosure" className="text-primary-dark dark:text-gold hover:underline font-medium">
          Learn more
        </a>
      </p>
    </div>
  );
}

import './globals.css';
import Header from '@/components/Header';
import Footer from '@/components/Footer';
import ScrollToTop from '@/components/ScrollToTop';
import SkipLinks from '@/components/SkipLinks';
import Script from 'next/script';

const inter = Inter({ subsets: ['latin'], display: 'swap', preload: true });

export const metadata: Metadata = {
  metadataBase: new URL('https://bookswar.com'),
  title: {
    default: 'Books War - We Compare Books (2026)',
    template: '%s | Books War',
  },
  description: 'Discover the perfect book for you! Compare bestsellers side-by-side with expert analysis, ratings, and honest reviews. Make smarter reading choices in 2026.',
  keywords: ['book comparison', 'book reviews', 'book recommendations', 'best books', 'reading', 'literature'],
  authors: [
    { name: 'Mehrab Musa', url: 'https://bookswar.com' },
    { name: 'Rufatul Islam' },
    { name: 'Safial Muntasir' },
    { name: 'Shoyaib Dipto' },
    { name: 'Abdullah Al Mamun' },
  ],
  creator: 'Mehrab Musa',
  publisher: 'Books War',
  openGraph: {
    type: 'website',
    locale: 'en_US',
    url: 'https://bookswar.com',
    siteName: 'Books War',
    title: 'Books War - We Compare Books (2026)',
    description: 'Discover the perfect book for you! Compare bestsellers side-by-side with expert analysis, ratings, and honest reviews.',
    images: [
      {
        url: '/og-image.svg',
        width: 1200,
        height: 630,
        alt: 'Books War - We Compare Books - Find Your Perfect Read',
      },
    ],
  },
  twitter: {
    card: 'summary_large_image',
    title: 'Books War - We Compare Books (2026)',
    description: 'Discover the perfect book for you! Compare bestsellers side-by-side with expert analysis.',
    images: ['/og-image.svg'],
